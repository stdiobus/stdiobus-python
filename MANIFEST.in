# Include documentation
include README.md
include LICENSE
include CHANGELOG.md

# Include type hints marker
include stdiobus/py.typed

# Include all Python source files
recursive-include stdiobus *.py
recursive-include stdiobus *.pyi

# Include native build header
recursive-include stdiobus/_native *.h

# Include tests for sdist
recursive-include tests *.py

# Exclude compiled files
global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__
global-exclude *.so
global-exclude .DS_Store

# Exclude development files
exclude .gitignore
exclude .pre-commit-config.yaml
prune .pytest_cache
prune .mypy_cache
prune .ruff_cache
